{
  "name": "drupal/recommended-project",
  "description": "Project template for Drupal 9 projects with a relocated document root",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "homepage": "https://www.drupal.org/project/drupal",
  "support": {
      "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
      "chat": "https://www.drupal.org/node/314178"
  },
  "repositories": [
      {
          "type": "composer",
          "url": "https://packages.drupal.org/8"
      },
      {
        "type": "composer",
        "url": "https://asset-packagist.org"
      },
      {
        "type": "package",
        "package": {
            "name": "billboardjs/billboard",
            "version": "3.4.1",
            "type": "drupal-library",
            "extra": {
                "installer-name": "billboard"
            },
            "dist": {
                "url": "https://registry.npmjs.org/billboard.js/-/billboard.js-3.4.1.tgz",
                "type": "tar"
            }
        }
      },
      {
        "type": "package",
        "package": {
            "name": "c3js/c3",
            "version": "v0.7.20",
            "type": "drupal-library",
            "extra": {
                "installer-name": "c3"
            },
            "dist": {
                "url": "https://github.com/c3js/c3/archive/v0.7.20.zip",
                "type": "zip"
            }
        }
      },
      {
		"type": "package",
		"package": {
		  "name": "d3/d3",
		  "version": "v4.9.1",
		  "type": "drupal-library",
		  "extra": {
			"installer-name": "d3"
		  },
		  "dist": {
		    "url": "https://github.com/d3/d3/archive/v4.9.1.zip",
			"type": "zip"
		  },
		  "require": {
			"composer/installers": "^1.0 || ^2.0"
		  }
		}
      },
      {
        "type": "package",
        "package": {
          "name": "dimsemenov/magnific-popup",
          "version": "4.17.1",
          "type": "drupal-library",
          "dist": {
            "url": "https://github.com/dimsemenov/Magnific-Popup/archive/refs/heads/master.zip",
            "type": "zip"
          }
        }
      },
      {
        "type": "package",
        "package": {
          "name": "ckeditor/autogrow",
          "version": "4.18.0",
          "type": "drupal-library",
          "dist": {
            "url": "https://download.ckeditor.com/autogrow/releases/autogrow_4.18.0.zip",
            "type": "zip"
          }
        }
      },
      {
        "type": "package",
        "package": {
          "name": "ckeditor/link",
          "version": "4.18.0",
          "type": "drupal-library",
          "dist": {
            "url": "https://download.ckeditor.com/link/releases/link_4.18.0.zip",
            "type": "zip"
          }
        }
      },
      {
        "type": "package",
        "package": {
          "name": "tippy/js",
          "version": "6.2.6",
          "type": "drupal-library",
          "dist": {
            "url": "https://unpkg.com/tippy.js@6.2.6/dist/tippy-bundle.umd.min.js",
            "type": "file"
          }
        }
      }
  ],
  "require": {
    "billboardjs/billboard": "3.4.1",
    "c3js/c3": "0.7.20",
    "civicrm/civicrm-asset-plugin": "^1.1",
    "civicrm/civicrm-core": "~6.10",
    "civicrm/civicrm-drupal-8": "~6.10",
    "civicrm/civicrm-packages": "~6.10",
    "civicrm/cli-tools": "*",
    "civicrm/composer-downloads-plugin": "^3.0",
    "ckeditor/autogrow": "^4.18",
    "ckeditor/link": "^4.18",
    "composer/installers": "^1.9",
    "drupal/address": "^1.12",
    "drupal/admin_toolbar": "^3.4",
    "drupal/allowed_formats": "^3.0",
    "drupal/anchor_link": "^3.0@alpha",
    "drupal/calendar_view": "^2.1",
    "drupal/charts": "^5.0",
    "drupal/civicrm_entity": "^4.0@beta",
    "drupal/civicrm_group_roles-civicrm_group_roles": "^1.3",
    "drupal/civicrm_member_roles": "^1.0@beta",
    "drupal/ckeditor_accordion": "^2.1",
    "drupal/coffee": "^2.0",
    "drupal/comment_notify": "^1.4",
    "drupal/config_delete": "^2.0",
    "drupal/config_single_export": "^1.4",
    "drupal/config_split": "^2.0",
    "drupal/contact_storage": "*",
    "drupal/content_moderation_notifications": "^3.6",
    "drupal/core-composer-scaffold": "10.6.4",
    "drupal/core-project-message": "10.6.4",
    "drupal/core-recommended": "10.6.4",
    "drupal/crop": "^2.4",
    "drupal/css_editor": "^2.0",
    "drupal/csv_serialization": "^4.0",
    "drupal/ctools": "^4.0",
    "drupal/d8w3css": "^2.0",
    "drupal/datetimehideseconds": "^1.4",
    "drupal/devel": "^5.5",
    "drupal/diff": "^1.1",
    "drupal/entity_browser": "^2.10",
    "drupal/entity_reference_revisions": "^1.11",
    "drupal/entity_usage": "^2.0@beta",
    "drupal/faqfield": "^7.1",
    "drupal/field_group": "^3.2",
    "drupal/file_delete": "^2.0",
    "drupal/fontawesome": "^2.26",
    "drupal/geocoder": "^4.21",
    "drupal/geofield": "^10.3",
    "drupal/geofield_map": "^11.1",
    "drupal/google_analytics": "*",
    "drupal/honeypot": "^2.1",
    "drupal/image_widget_crop": "^3.0",
    "drupal/inline_entity_form": "^3.0@RC",
    "drupal/key": "^1.22",
    "drupal/kint": "^2.3",
    "drupal/layout_builder_admin_theme": "^2.0",
    "drupal/layout_builder_restrictions": "^2.19",
    "drupal/layout_paragraphs": "^2.0",
    "drupal/leaflet": "^10.2",
    "drupal/magnific_popup": "^2.0",
    "drupal/mail_login": "^4.0",
    "drupal/masquerade": "^2.1",
    "drupal/menu_admin_per_menu": "^1.5",
    "drupal/node_revision_delete": "^2.0@alpha",
    "drupal/paragraphs": "^1.17",
    "drupal/pathauto": "^1.12",
    "drupal/permission_spreadsheet": "^2.0",
    "drupal/quick_node_clone": "^1.17",
    "drupal/role_delegation": "^1.2",
    "drupal/scheduler": "^1.5",
    "drupal/shortcutperrole": "^2.0",
    "drupal/smart_date": "^4.2",
    "drupal/svg_image": "^3.0",
    "drupal/symfony_mailer": "^1.4",
    "drupal/tac_lite": "^1.7",
    "drupal/tamper": "^1.0@alpha",
    "drupal/theme_switcher": "^2.0",
    "drupal/token": "^1.13",
    "drupal/tooltip_taxonomy": "^2.1",
    "drupal/typed_data": "^2.1",
    "drupal/view_unpublished": "^1.1",
    "drupal/views_bulk_operations": "^4.2",
    "drupal/views_data_export": "^1.4",
    "drupal/views_infinite_scroll": "^2.0",
    "drupal/views_local_tasks": "^1.0",
    "drupal/views_slideshow": "^5.0",
    "drupal/views_year_filter": "^2.1",
    "drupal/webform": "^6.0",
    "drupal/webform_civicrm": "^6.2",
    "drupal/webform_views": "^5.2",
    "geocoder-php/google-maps-provider": "^4.7",
    "npm-asset/fonticonpicker--fonticonpicker": ">=1.0",
    "npm-asset/fortawesome--fontawesome-free": "5.15",
    "oomphinc/composer-installers-extender": "^2.0",
    "stripe/stripe-php": "^16.3",
    "tippy/js": "^6.2.6",
    "wikimedia/composer-merge-plugin": "^2.1"
  },
  "conflict": {
      "drupal/drupal": "*"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "civicrm/civicrm-asset-plugin": true,
      "civicrm/composer-compile-plugin": true,
      "civicrm/composer-downloads-plugin": true,
      "composer/installers": true,
      "cweagans/composer-patches": false,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "drupal/core-composer-scaffold": true,
      "drupal/core-project-message": true,
      "oomphinc/composer-installers-extender": true,
      "php-http/discovery": true,
      "wikimedia/composer-merge-plugin": true
    },
    "sort-packages": true
  },
  "extra": {
      "drupal-scaffold": {
          "locations": {
              "web-root": "web/"
          }
      },
      "installer-paths": {
          "web/core": [
              "type:drupal-core"
          ],
          "web/libraries/{$name}": [
              "type:drupal-library",
              "type:npm-asset",
              "npm-asset/fortawesome--fontawesome-free",
              "npm-asset/fonticonpicker--fonticonpicker"
          ],
          "web/modules/contrib/{$name}": [
              "type:drupal-module"
          ],
          "web/profiles/contrib/{$name}": [
              "type:drupal-profile"
          ],
          "web/themes/contrib/{$name}": [
              "type:drupal-theme"
          ],
          "drush/Commands/contrib/{$name}": [
              "type:drupal-drush"
          ],
          "web/modules/custom/{$name}": [
              "type:drupal-custom-module"
          ],
          "web/profiles/custom/{$name}": [
              "type:drupal-custom-profile"
          ],
          "web/themes/custom/{$name}": [
              "type:drupal-custom-theme"
          ]
      },
      "drupal-core-project-message": {
          "include-keys": [
              "homepage",
              "support"
          ],
          "post-create-project-cmd-message": [
              "<bg=blue;fg=white>                                                         </>",
              "<bg=blue;fg=white>  Congratulations, you’ve installed the Drupal codebase  </>",
              "<bg=blue;fg=white>  from the drupal/recommended-project template!          </>",
              "<bg=blue;fg=white>                                                         </>",
              "",
              "<bg=yellow;fg=black>Next steps</>:",
              "  * Install the site: https://www.drupal.org/docs/8/install",
              "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
              "  * Get support: https://www.drupal.org/support",
              "  * Get involved with the Drupal community:",
              "      https://www.drupal.org/getting-involved",
              "  * Remove the plugin that prints this message:",
              "      composer remove drupal/core-project-message"
          ]
      },
      "enable-patching": "true",
      "patches": {
        "drupal/smart_date": {
            "D10.2 Smart date list item must pass as array": "https://www.drupal.org/files/issues/2023-12-18/3409287.patch"
        }
      },
      "merge-plugin": {
          "include": [
              "web/modules/contrib/charts/modules/charts_c3/composer.json",
              "web/modules/contrib/anchor_link/composer.libraries.json"
          ]
      },
      "compile-whitelist": ["civicrm/civicrm-core", "civicrm/composer-compile-lib"]
  },
  "require-dev": {
    "drush/drush": "^13"
  }
}
