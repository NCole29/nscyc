{% extends "block.html.twig" %}
{#
/**
 * @file
 * Replaces content block to:
 *   Override - change alt = 'Home' to alt = 'Site logo' else its confusing.
 *   Add message to upload logo.
 */
#}
{% block content %}
  {% if site_logo %}
    <a href="{{ path('<front>') }}" title="{{ 'Home'|t }}" rel="home" class="w3-left w3-padding-16 site-logo">
      <img src="{{ site_logo }}" style="max-height:100px; width:auto;" alt="{{ 'Site logo'|t }}" />
    </a>
  {% endif %}
<div class="w3-left w3-margin-left site-name-slogan">
  {% if site_name %}
    <h1 class="site-name w3-show-block">
      <a class="w3-xlarge w3-padding" href="{{ path('<front>') }}" title="{{ 'Home'|t }}" rel="home">{{ site_name }}</a>
    </h1>
  {% endif %}
  {% if site_slogan %}
    <h3 class="site-slogan w3-large w3-show-block">{{ site_slogan }}</h3>
  {% endif %}
</div>
{% endblock %}
