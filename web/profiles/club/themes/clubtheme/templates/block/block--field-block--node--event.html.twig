{#
/**
 * @file
 * Theme override for Event page - Event and Location titles
 * Remove w3-padding from H2 classes
 *
 */
#}

{%
  set classes = [
    'w3-block',
    'w3-block-wrapper',
    'block-' ~ configuration.provider|clean_class,
    'block-' ~ plugin_id|clean_class,
  ]
%}
<section{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    <h2{{ title_attributes.addClass('w3-block-title') }}>{{ label }}</h2>
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    {{ content }}
  {% endblock %}
</section>
