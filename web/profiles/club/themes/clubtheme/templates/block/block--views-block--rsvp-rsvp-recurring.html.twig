{#
/**
 * Overrides block--views-block.html.twig
 * Display title as <field_label> instead of <h2>.
 * <h2> is hardcoded so can't change with attributes.
 */
#}

{%
  set classes = [
    'w3-block',
    'w3-block-wrapper',
    'block-' ~ configuration.provider|clean_class,
    'block-' ~ plugin_id|clean_class,
  ]
%}
<section{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if label %}
    <label class="field__label">{{ label }}</label>
  {% endif %}
  {{ title_suffix }}
  {% block content %}
    {{ content }}
  {% endblock %}
</section>
