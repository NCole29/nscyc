{#
/**
 * @file
 * Theme override to display an ARTICLE node.
 *  Display field_author and field_article_date outside of CONTENT object.
 *   This allows us to style the separate fields via field__xxx.html.twig.
 */
#}
{%
  set classes = [
    'w3-row',
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>

  {{ title_prefix }}
  {% if not page %}
    <h3 {{ title_attributes.addClass('w3-margin-left node__title') }}>
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h3>
  {% endif %}
  {{ title_suffix }}

  {% if display_submitted %}
    <footer class="node__meta">
      {{ author_picture }}
      <div{{ author_attributes.addClass('w3-small node__submitted') }}>
        {% trans %}Submitted by: {{ author_name }} <br> on {{ date }}{% endtrans %}
        {{ metadata }}
      </div>
    </footer>
  {% endif %}

  {# PULLED AUTHOR & DATE OUT TO USE FIELD TEMPLATES - SEE [FIELD].HTML.TWIG #}
  {{ content.field_author }}
  {{ content.field_article_date }}

  <div{{ content_attributes.addClass('w3-container node__content') }}>
    {{ content|without('field_author','field_article_date','field_timestamp') }}
  </div>

</article>
