{#
/**
 * @file
 * Template override for location node teaser.
 * Removes hardcoded <h3> tag, link on location title (placename),
 *  and <div> around content.
 *
 */
#}
{%
  set classes = [
    'w3-row',
    'node',
    'node--type-' ~ node.bundle|clean_class,
    node.isPromoted() ? 'node--promoted',
    node.isSticky() ? 'node--sticky',
    not node.isPublished() ? 'node--unpublished',
    view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  ]
%}

<article{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if not page %}
    {{ label }} <small>({{ content.field_google_map.0 }})</small>
  {% endif %}
  {{ title_suffix }}
</article>
