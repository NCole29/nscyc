{% extends "field.html.twig" %}
{#
   This field <div> controls image alignment, not size
   Remove w3-section
   Add classes for image alignment
   See clubtheme.theme for preprocess function to change image size
#}

{% if element['#object'].field_image_placement.value == 'right' %}
  {% set position = 'w3-right' %}
{% else %}
  {% set position = 'w3-left' %}
{% endif %}

{% set new_classes = [
  position,
	'w3-margin-right',
	'w3-margin-left',
  'w3-margin-bottom',
	]
%}

{% set remove_class = 'w3-section' %}
{% set attributes = attributes.addClass(classes, new_classes) %}
