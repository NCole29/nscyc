{#
/**
 * @file
 * Changed 'w3-button' to 'w3-button-submit' to apply darkest color to submit buttons
 *  without changing buttons on menus, etc.
 */
#}
{%
  set classes = [
    'w3-margin-top8',
    'w3-button-submit',
    'w3-border',
    'w3-theme-border',
    'w3-margin-bottom',
	'w3-padding',
  ]
%}
<input{{ attributes.addClass(classes) }} />{{ children }}
