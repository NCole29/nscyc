4166424 27.7914216,25.4166424 C24.1194363,25.4166424 21.676262,22.7958756 22.0976747,22.164255 C22.1027283,22.1566805 22.107639,22.1496945 22.1124114,22.1432602 C23.2347105,23.1960695 25.0698091,24.3094734 26.9209999,24.3094734 C30.4604522,24.3094734 33.3297452,21.5632739 33.3297452,18.1756651 C33.3297452,14.7880563 31.0168199,12.5472945 27.4951492,12.2283166 C25.9731481,12.0904602 25.0936786,12.3861432 24.1542453,12.8592361 C23.3483353,13.2650874 22.3126737,14.1621723 21.5185904,14.983152 Z" id="Combined-Shape"></path>
                         <path d="M24.6916908,5.51565483 C25.8124808,5.51565483 27.1030207,4.57605427 27.1030207,3.09333115 C27.1030207,1.61060804 25.6467991,0.65767234 24.2976113,0.393929295 C21.607445,-0.131952035 18.8480645,0.579279099 18.060989,1.86913836 C18.060989,1.86913836 18.3559913,1.76566855 18.7593026,1.67455868 C19.8115965,1.43684063 20.8502522,1.60551697 21.691771,2.13712575 C22.0658816,2.37346094 22.1126376,2.87325952 22.1106112,2.93148026 C22.0491134,4.69841739 23.5709009,5.51565483 24.6916908,5.51565483 Z" id="Oval-3" transform="translate(22.582005, 2.867498) rotate(-2.000000) translate(-22.582005, -2.867498) "></path>
                        </g>
                      </g>
                    </g>
                   </svg>
                  </a>
                {% endif %}
                {% if strava_url %}
                  <a href="{{ strava_url }}" target="_blank" >
                    <svg xmlns="http://www.w3.org/2000/svg" width="120" height="40">
                     <path fill="{{ iconcolor}}" d="M13.447 35.846l2.973-3.558c1.82 1.386 3.892 1.97 5.846 1.97 1.002 0 1.437-.267 1.437-.718v-.05c0-.484-.518-.735-2.305-1.102-3.742-.768-7.032-1.837-7.032-5.362v-.05c0-3.174 2.472-5.63 7.082-5.63 3.224 0 5.596.768 7.533 2.288l-2.74 3.775a8.68 8.68 0 0 0-5.011-1.637c-.835 0-1.22.284-1.22.685v.05c0 .45.45.735 2.222 1.07 4.276.785 7.132 2.02 7.132 5.395v.033c0 3.508-2.9 5.646-7.366 5.646-3.39.017-6.43-.935-8.552-2.806zm21.48-9.454h-4.91v-4.727h15.4v4.727h-4.91v11.96h-5.58zm24.337 6.28c2.02-.986 3.29-2.673 3.29-5.095v-.05c0-1.72-.518-2.957-1.52-3.96-1.17-1.17-3.057-1.904-6.013-1.904h-8.15v16.687h5.58v-4.76h1.186l3.14 4.76h6.364zm-2.272-4.694c0 1.02-.818 1.62-2.138 1.62H52.45v-3.257h2.44c1.286 0 2.12.518 2.12 1.604v.033zm14.098-7.016l-9.003 17.39h5.98l3.023-6.08 3.023 6.08h5.98zm26.46 0l-9.003 17.39h5.98l3.023-6.08 3.023 6.08h5.98zM84.32 39.037l9.02-17.39h-5.98l-3.023 6.08-3.04-6.08h-5.98z"/>
                    </svg>
                  </a>
                {% endif %}
              {% endif %}

              {# CLUBTHEME - IF NOT SHOWING ICONS, SHOW TEXT #}
              {% if has_social == 1 and show_social_icon != 1 %}
                {% if facebook_url %}
                  <a href="{{ facebook_url }}" class='w3-social' target="_blank">Facebook</a><br>
                {% endif %}
                {% if twitter_url %}
                  <a href="{{ twitter_url }}" class='w3-social' target="_blank">Twitter</a><br>
                {% endif %}
                {% if pinterest_url %}
                  <a href="{{ pinterest_url }}" class='w3-social' target="_blank">Pinterest</a><br>
                {% endif %}
                {% if google_plus_url %}
                  <a href="{{ google_plus_url }}" class='w3-social' target="_blank">Google Plus</a><br>
                {% endif %}
                {% if linkedin_url %}
                  <a href="{{ linkedin_url }}" class='w3-social' target="_blank">LinkedIn</a><br>
                {% endif %}
                {% if instagram_url %}
                  <a href="{{ instagram_url }}" class='w3-social' target="_blank">Instagram</a><br>
                {% endif %}
                {% if youtube_url %}
                  <a href="{{ youtube_url }}" class='w3-social' target="_blank">YouTube</a><br>
                {% endif %}
                {% if rss_url %}
                  <a href="{{ rss_url }}" class='w3-social' target="_blank">Rss</a><br>
                {% endif %}
                {% if rwgps_url %}
                  <a href="{{ rwgps_url }}" class='w3-social' target="_blank">Ride With GPS</a><br>
                {% endif %}
                {% if strava_url %}
                  <a href="{{ strava_url }}" class='w3-social' target="_blank" >Strava</a><br>
                {% endif %}
              {% endif %}
              <!-- End: Footer Third -->
            </div>
          </div>
          <!-- End: Footer -->
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if page.footer_menu %}
    <!-- Start: Footer Menu -->
    <div id="footer-menu" class="w3-col w3-clear w3-theme-white {{ color_footer_menu }}">
      <div id="footer-menu-inner" class="w3-row footer-menu-inner {{ website_width }}">
        <!-- Start: Bottom Menu -->
        {% if page.footer_menu %}
          <div class="d8-fade w3-center w3-mobile">
            {{ page.footer_menu }}
          </div>
          <!-- End: Bottom Menu -->
        {% endif %}
      </div>
    </div>
    <!-- End: Footer Menu -->
  {% endif %}
  {% if copyright_text or show_credit_link %}
    <!-- Start: Copyright -->
    <div id="copyright" class="w3-col w3-clear w3-theme-d5 {{ color_copyright }}">
      <div id="copyright-inner" class="w3-row copyright-inner {{ website_width }}">
        {% if copyright_text %}
          <!-- Start: Copyright -->
          <div class="w3-half w3-container w3-mobile">
            <p class="w3-section w3-left-align w3-opacity w3-hover-opacity-off">{{copyright_text}}</p>
          </div>
          <!-- End: Copyright -->
        {% endif %}
        {% if show_credit_link %}
          <!-- Start: Credit Link -->
          <div class="w3-half w3-container w3-mobile">
            <p class="w3-section w3-right-align w3-opacity w3-hover-opacity-off">Developed &#38; Designed by: <a href="https://www.alaahaddad.com" title="Alaa Haddad" target="_blank">Alaa Haddad</a></p>
          </div>
          <!-- End: Credit Link -->
        {% endif %}
      </div>
    </div>
    <!-- End: Copyright -->
  {% endif %}
</div>

<!-- End: Page Wrapper -->
