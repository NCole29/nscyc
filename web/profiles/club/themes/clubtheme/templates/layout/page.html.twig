{#
/**
 * @file
 * OVERRIDE of V2 page template
 * Moved social icons from footer menu to Footer Third Container (page.footer_third)
 * Changed Welcome block to add club-border-bottom
 * Added Banner_pictures block
 * Added "if page.canceled" for cancellation block at start of page wrapper
 * Change all footer-container colors to w3-theme-d5: lines 262,268,277,286,392
 *
 * @see template_preprocess_page()
 * @see html.html.twig
 */
#}

{% if page.primary_menu_vertical %}
  <!-- Start: Main Navigation - Vertical -->
  <div id="main-navigation-v" class="main-navigation-wrapper w3-sidebar w3-bar-block w3-animate-left w3-card w3-theme {{ color_primary_menu }}" role="navigation" aria-label="{{ 'Main Navigation'|t }}" >
    <div id="main-navigation-inner-v" class="main-navigation-inner-v">
      <div id="close-nav" class="close-nav w3-button w3-bar-block w3-large w3-theme {{ color_primary_menu }}">
        <i class="fa fa-close"></i>
      </div>
        {{ page.primary_menu_vertical }}
    </div>
  </div>
  <!-- End: Main Navigation - Vertical -->
{% endif %}

<!-- Start: Page Wrapper -->
<div class="page-wrapper w3-col w3-clear w3-animate-opacity w3-text-theme {{ color_page_wrapper }} ">

  {% if page.canceled %}
  <!-- Start: Canceled rides block. Block limited to <front> in block configuration. -->
	<div id="canceled-rides" class="w3-col w3-clear">
	  {{ page.canceled }}
	</div>
  {% endif %}

  <!-- Default page has Header then primary_menu -->
  <!-- CLUBTHEME - conditionally place primary_menu on top and add club-border-bottom to header classes-->
  {% if topnav %}
    {% if page.primary_menu %}
    <!-- Start: Main Navigation - Horizontal -->
    <div id="main-navigation-h" class="w3-col w3-clear main-navigation-wrapper w3-theme {{ color_primary_menu }}" role="navigation" aria-label="{{ 'Main Navigation'|t }}" >
      <div id="main-navigation-inner-h" class="w3-row main-navigation-inner-h {{ website_width }}">
        <div class="mobile-nav w3-hide-large w3-button w3-block w3-right-align w3-large w3-theme {{ color_primary_menu }}">
          <i class="fa fa-bars"></i>
        </div>
          {{ page.primary_menu }}
      </div>
    </div>
    <!-- End: Main Navigation - Horizontal -->
    {% endif %}
    <!-- Start: Header -->
    <header id="header" class="w3-col w3-clear club-border-bottom w3-theme-l4 {{ color_header }}" role="banner" aria-label="{{ 'Site header'|t }}">
      <div id="header-inner" class="w3-container header-inner {{ website_width }}">
        {% if page.primary_menu_vertical %}
          <div id="open-nav-inner" class="open-nav-inner w3-left w3-button w3-left-align w3-large w3-theme {{ color_primary_menu }}">
            <i class="fa fa-bars"></i>
          </div>
        {% endif %}
          {{ page.header }}
      </div>
    </header>
  {% else %}
    <!-- Start: Header -->
    <header id="header" class="w3-col w3-clear w3-theme-l4 {{ color_header }}" role="banner" aria-label="{{ 'Site header'|t }}">
      <div id="header-inner" class="w3-container header-inner {{ website_width }}">
        {% if page.primary_menu_vertical %}
          <div id="open-nav-inner" class="open-nav-inner w3-left w3-button w3-left-align w3-large w3-theme {{ color_primary_menu }}">
            <i class="fa fa-bars"></i>
          </div>
        {% endif %}
          {{ page.header }}
      </div>
    </header>
    <!-- End: Header -->
    {% if page.primary_menu %}
    <!-- Start: Main Navigation - Horizontal -->
    <div id="main-navigation-h" class="w3-col w3-clear main-navigation-wrapper w3-card w3-theme {{ color_primary_menu }}" role="navigation" aria-label="{{ 'Main Navigation'|t }}" >
      <div id="main-navigation-inner-h" class="w3-row main-navigation-inner-h {{ website_width }}">
        <div class="mobile-nav w3-hide-large w3-button w3-block w3-right-align w3-large w3-theme {{ color_primary_menu }}">
          <i class="fa fa-bars"></i>
        </div>
          {{ page.primary_menu }}
      </div>
    </div>
    <!-- End: Main Navigation - Horizontal -->
    {% endif %}
  {% endif %}
  {% if is_front and page.welcome_text %}
    <!-- Start: Welcome Text - CLUBTHEME adds border-bottom -->
    <div id="welcome-text" class="w3-col w3-clear w3-theme-l5 club-border-bottom {{ color_welcome_text }}">
      <div id="welcome-text-inner" class="w3-row welcome-text-inner {{ website_width }}">
        {{ page.welcome_text }}
      </div>
    </div>
    <!-- End: Welcome Text -->
  {% endif %}
  {% if page.highlighted %}
    <!-- Start: Highlighted -->
    <div id="highlighted" class="w3-col w3-clear w3-theme-l2 {{ color_highlighted}}">
      <div id="highlighted-inner" class="d8-fade w3-row highlighted-inner {{ website_width }}">
        {{ page.highlighted }}
      </div>
    </div>
    <!-- End: Highlighted -->
  {% endif %}
  {% if is_front %}
    {% if page.top_first or page.top_second or page.top_third %}
      <!-- Start: Top Container -->
      <div id="top-container" class="w3-col w3-clear w3-theme-l4 {{ color_top_container }}">
        <div id="top-container-inner" class="w3-row-padding top-container-inner {{ website_width }}">
          {% if page.top_first %}
            <!-- Start: Top container first region -->
            <div class="{{ top_w3css }} top-box {{ top_region ? 'top-region' }} first-top" >
              <div class="d8-fade w3-mobile w3-theme-l5 {{ color_top_first}}">
               {{ page.top_first }}
              </div>
            </div>
            <!-- End: Top Container First -->
          {% endif %}
          {% if page.top_second %}
            <!-- Start: Top Container Second  -->
            <div class="{{ top_w3css }} top-box {{ top_region ? 'top-region' }} second-top">
              <div class="d8-fade w3-mobile w3-theme-l5 {{ color_top_second }}">
               {{ page.top_second }}
              </div>
            </div>
            <!-- End: Top Container Second -->
          {% endif %}
          {% if page.top_third %}
          <!-- Start: Top Container Third -->
          <div class="{{ top_w3css }} top-box {{ top_region ? 'top-region' }} third-top">
            <div class="d8-fade w3-mobile w3-theme-l5 {{ color_top_third }}">
              {{ page.top_third }}
            </div>
          </div>
          <!-- End: Top Container Third -->
          {% endif %}
        </div>
      </div>
      <!-- End: Top container -->
    {% endif %}
  {% endif %}

  {% if page.banner_pictures %}
    <!-- Start: Banner pictures -->
    <div id="page-banner" class="w3-col w3-clear">
      {{ page.banner_pictures }}
    </div>
	<!-- End: Banner pictures -->
  {% endif %}

  {% if page.page_title and not is_front %}
    <!-- Start: Page Title -->
    <div id="page-title" class="w3-col w3-clear w3-theme-d5 {{ color_page_title }}">
      <div id="page-title-inner" class="d8-fade w3-row page-title-inner {{ website_width }}">
        {{ page.page_title }}
      </div>
    </div>
    <!-- End: Page Title -- >
  {% endif %}

  <!-- Start: Main -->
  <div id="main-container" class="w3-col w3-clear w3-theme-l5 {{ color_main }}">
    <div id="main-container-inner" class="w3-row main-container-inner {{ website_width }}">
      {% if page.breadcrumb|render|striptags|trim %}
        <!-- Breadcrumb -->
        <div class="w3-row {{ color_breadcrumb }}">
          {{ page.breadcrumb }}
        </div>
        <!-- End: Breadcrumb -->
      {% endif %}
      <!-- Start Main Container  -->
      <div class="w3-col w3-clear w3-row-padding">
        {% if page.sidebar_first %}
          <!-- Start Left SideBar -->
          <div class ="{{ sidebarfirst }} main-box {{ main_region ? 'main-region' }} first-sidebar" role="complementary">
            <div class="d8-fade w3-sidebar-first w3-mobile {{ color_sidebar_first }}">
              {{ page.sidebar_first }}
            </div>
          </div>
          <!-- End: Left SideBar -->
        {% endif %}
        {% if page.content %}
          <!-- Start: Main Content -->
          <div class="{{ content_w3css }} main-box {{ main_region ? 'main-region' }} w3css-content" role="main">
            <div class="d8-fade w3-mobile  {{ color_content }}">
			       {{ page.content }}
            </div>
          </div>
          <!-- End: Main Content -->
        {% endif %}
        {% if page.sidebar_second %}
          <!-- Start: Right SideBar -->
          <div class="{{ sidebarsecond }} main-box {{ main_region ? 'main-region' }} second-sidebar" role="complementary">
            <div class="d8-fade w3-sidebar-second w3-mobile {{ color_sidebar_second }}">
              {{ page.sidebar_second }}
            </div>
          </div>
          <!-- End: Right SideBar -->
        {% endif %}
      </div>
      <!-- End: Main Container  -->
    </div>
  </div>
  <!-- End: Main -->
  {% if is_front %}
    {% if page.full_width_blocks %}
      <!-- Start: Full width blocks. Alternating bkgrd color set by blocknum counter -->
      <div id="full_width" class="w3-col w3-clear full-width-blocks">
        {% set blocknum = 0 %}
        {% for block_key, block in page.full_width_blocks %}
          {% if block_key|first != '#' %}
            {% set blocknum = blocknum + 1 %}
            {% if blocknum is odd %}
              <div id="full-width-block" class="w3-clear w3-theme-d5 club-border-top club-border-bottom">
                <div class="full-width-blocks-inner">
                  {{ block }}
                </div>
              </div>
				  
            {% else %}
              <div id="full-width-block" class="w3-clear w3-theme-white club-border-bottom">
                <div class="full-width-blocks-inner">
                  {{ block }}
                </div>
              </div>
            {% endif %}
          {% endif %}
        {% endfor %}      
      </div>
    <!-- End: Full width blocks -->
    {% endif %}

    {% if page.bottom_first or page.bottom_second or page.bottom_third or page.bottom_forth %}
      <!-- Start: Bottom -->
      <div id="bottom-container" class="w3-col w3-clear w3-theme-l2 {{ color_bottom_container }}">
        <div id="bottom-container-inner" class="w3-row-padding bottom-container-inner {{ website_width }}">
            {% if page.bottom_first %}
              <!-- Start: Bottom First -->
              <div class="{{ bottom_w3css }} bottom-box {{ bottom_region ? 'bottom-region' }} first-bottom">
                <div class="d8-fade w3-mobile w3-theme-white {{ color_bottom_first }}">
                  {{ page.bottom_first }}
                </div>
              </div>
              <!-- End: Bottom First -->
            {% endif %}
            {% if page.bottom_second %}
              <!-- Start: Bottom Second -->
              <div class="{{ bottom_w3css }} bottom-box {{ bottom_region ? 'bottom-region' }} second-bottom">
                <div class="d8-fade w3-mobile w3-theme-l4 {{ color_bottom_second }}">
                  {{ page.bottom_second }}
                </div>
              </div>
              <!-- End: Bottom Second -->
            {% endif %}
            {% if page.bottom_third %}
              <!-- Start: Bottom Third  -->
              <div class="{{ bottom_w3css }} bottom-box {{ bottom_region ? 'bottom-region' }} third-bottom">
                <div class="d8-fade w3-mobile w3-theme-l4 {{ color_bottom_third }}">
                  {{ page.bottom_third }}
                </div>
              </div>
              <!-- End: Bottom Third -->
            {% endif %}
            {% if page.bottom_forth %}
              <!-- Start: Bottom Forth  -->
              <div class ="{{ bottom_w3css }} bottom-box {{ bottom_region ? 'bottom-region' }} forth-bottom">
                <div class="d8-fade w3-mobile w3-theme-l4 {{ color_bottom_forth }}">
                  {{ page.bottom_forth }}
                </div>
              </div>
              <!-- End: Bottom Forth -->
            {% endif %}
        </div>
      </div>
      <!-- End: Bottom -->
    {% endif %}
  {% endif %}

{#
   CLUBTHEME - MOVED SOCIAL ICONS FROM FOOTER MENU TO page.footer.third
    so we add "or show_social_icon" to conditions
#}
  {% if page.footer_first or page.footer_second or page.footer_third or show_social_icon %}
    <!-- start: Footer -->
    <div id="footer-container" class="w3-col w3-clear w3-theme-d3 {{ color_footer_container }}">
      <div id="footer-container-inner" class="w3-row-padding footer-container-inner {{ website_width }}">

      {# Use checkbox results to set footer blocks same color as container (solid footer) #}
      {% if solid_footer == 1 %}
        {% set fcolor1,fcolor2,fcolor3,iconfill,iconcolor = 'w3-theme-d3','w3-theme-d3','w3-theme-d3','w3-text-white','#ffffff' %}
      {% else %}
        {% set fcolor1,fcolor2,fcolor3,iconfill,iconcolor = 'w3-theme-l4','w3-theme-l5','w3-theme-l4','w3-text-black','#000000' %}
      {% endif %}

        {% if page.footer_first %}
          <!-- Start: Footer First  -->
        <div class="{{ footer_w3css }} footer-box {{ footer_region ? 'footer-region' }} first-footer">
          <div class="d8-fade w3-mobile {{ border_animation ? 'animate-border' }} {{ fcolor1 }} {{ color_footer_first }}">
              {{ page.footer_first }}
            </div>
          </div>
          <!-- End: Footer First -->
        {% endif %}
        {% if page.footer_second %}
          <!-- Start: Footer Second Region -->
        <div class="{{ footer_w3css }} footer-box {{ footer_region ? 'footer-region' }} second-footer">
          <div class="d8-fade w3-mobile {{ border_animation ? 'animate-border' }} {{ fcolor2 }} {{ color_footer_second }}">
              {{ page.footer_second }}
            </div>
          </div>
        <!-- End: Footer Second -->
        {% endif %}
        {% if page.footer_third or has_social == 1 %}
          <!-- Start: Footer Third -->
      <div class="{{ footer_w3css }} footer-box {{ footer_region ? 'footer-region' }} third-footer">
        <div class="d8-fade w3-mobile {{ border_animation ? 'animate-border' }} {{ fcolor3 }} {{ color_footer_third }}">
              {{ page.footer_third }}

              {# CLUBTHEME - MOVED SOCIAL ICONS FROM FOOTER MENU TO HERE #}
              {% if show_social_icon %}
                <!-- Start: Social Media -->
                {% if facebook_url %}
                  <a href="{{ facebook_url }}" class="{{ iconfill }} w3-icon w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank" >
                  <i class="fab fa-facebook"></i></a>
                {% endif %}
                {% if twitter_url %}
                  <a href="{{ twitter_url }}" class="{{ iconfill }} w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank" >
                  <i class="fab fa-twitter"></i></a>
                {% endif %}
                {% if pinterest_url %}
                  <a href="{{ pinterest_url }}" class="{{ iconfill }} w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank">
                  <i class="fab fa-pinterest"></i></a>
                {% endif %}
                {% if google_plus_url %}
                  <a href="{{ google_plus_url }}" class="{{ iconfill }} w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank" >
                  <i class="fab fa-google-plus"></i></a>
                {% endif %}
                {% if linkedin_url %}
                  <a href="{{ linkedin_url }}" class="{{ iconfill }} w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank">
                  <i class="fab fa-linkedin"></i></a>
                {% endif %}
                {% if instagram_url %}
                  <a href="{{ instagram_url }}" class="{{ iconfill }} w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank">
                  <i class="fab fa-instagram"></i></a>
                {% endif %}
                {% if youtube_url %}
                  <a href="{{ youtube_url }}" class="{{ iconfill }} w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank">
                  <i class="fab fa-youtube"></i></a>
                {% endif %}
                {% if drupal_url %}
                  <a href="{{ drupal_url }}" class="{{ iconfill }} w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank" >
                  <i class="fab fa-drupal"></i></a>
                {% endif %}
                {% if rss_url %}
                  <a href="{{ rss_url }}" class="{{ iconfill }} w3-hover-opacity w3-show-inline-block w3-xlarge w3-padding" target="_blank" >
                  <i class="fab fa-rss"></i></a>
                {% endif %}
                <!-- Start: Cycling Links -->
                {% if rwgps_url %}
                  <a href="{{ rwgps_url }}" target="_blank" >
                   {# SVG from https://ridewithgps.com/help/ #}
                   <svg width="36px" height="26px" viewBox="0 0 36 26" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                    <!-- Generator: Sketch 46.2 (44496) - http://www.bohemiancoding.com/sketch -->
                    <title>Ride with GPS logo</title>
                    <desc>Created with Sketch</desc>
                    <defs></defs>
                    <g id="Stylesheet" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                     <g id="06" transform="translate(-1054.000000, -502.000000)" fill= "{{ iconcolor }}">
                     <g id="logo" transform="translate(1054.000000, 502.000000)">
