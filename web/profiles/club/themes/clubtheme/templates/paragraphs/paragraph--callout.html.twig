{% extends "paragraph.html.twig" %}
{#
  Light background
  Dark background
  No background
#}
{%
  set callout_classes = [
    'w3-leftbar',
	paragraph.field_callout_height.value,
	paragraph.field_card_width.value,	
    paragraph.field_background.value,
	paragraph.field_callout_border.value ? 'w3-no-leftbar' : 'w3-leftbar',
  ]
%}

{%  set attributes = attributes.addClass(classes, callout_classes) %}
